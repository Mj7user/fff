              "raw": "{{baseUrl}}/users/1/status?status=ACTIVE",
              "host": ["{{baseUrl}}"],
              "path": ["users", "1", "status"],
              "query": [{ "key": "status", "value": "ACTIVE", "description": "ACTIVE | INACTIVE | SUSPENDED" }]
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/users/1", "host": ["{{baseUrl}}"], "path": ["users", "1"] }
          }
        }
      ]
    },
