            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Updated\",\n  \"email\": \"jane.officer@civicaid.com\",\n  \"phone\": \"9876543299\",\n  \"role\": \"WELFARE_OFFICER\",\n  \"status\": \"ACTIVE\"\n}"
